# Copy to env.local and fill in (env.local is gitignored).
# Docs: https://developer.webull.com/apis/docs/authentication/overview.md

# Required for signed calls
WEBULL_APP_KEY=
WEBULL_APP_SECRET=

# HTTP API host (production per Quick Start). UAT example from OpenAPI specs:
# us-openapi-alb.uat.webullbroker.com
WEBULL_API_HOST=api.webull.com

# Optional: after GET /openapi/account/list you can paste one id here to skip picking the first.
WEBULL_ACCOUNT_ID=

# Optional: required for many trading/asset endpoints when 2FA is enabled on your app.
# Create / verify via Webull app — see https://developer.webull.com/apis/docs/authentication/token.md
WEBULL_ACCESS_TOKEN=
